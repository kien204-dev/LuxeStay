# Server
PORT=3001
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# PostgreSQL Neon
DB_HOST=ep-flat-shape-aowhnsvq.c-2.ap-southeast-1.aws.neon.tech
DB_PORT=5432
DB_NAME=neondb
DB_USER=neondb_owner
DB_PASSWORD=replace_with_your_neon_database_password

# Authentication
JWT_SECRET=replace_with_a_long_random_secret
AUTH_TOKEN_TTL=1d
AUTH_COOKIE_NAME=luxestay_session
AUTH_COOKIE_MAX_AGE_MS=86400000
# Local development. Use true + SameSite=none when frontend/backend are cross-site HTTPS.
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
TRUST_PROXY_HOPS=1

# Firebase Admin (never expose the service-account JSON to the frontend)
FIREBASE_PROJECT_ID=booking-hotel-be19e
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"replace_me"}

# Password reset
RESET_TOKEN_TTL_MINUTES=15

# SMTP email service
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM="LuxeStay <no-reply@example.com>"
